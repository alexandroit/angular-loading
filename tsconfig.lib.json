{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": true,
    "inlineSources": true,
    "lib": [
      "dom",
      "es2022"
    ],
    "outDir": "./out-tsc/lib",
    "rootDir": "."
  },
  "include": [
    "index.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-legacy",
    "docs",
    "docs-src"
  ]
}
